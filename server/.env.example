POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=todolist
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

CORS_ORIGINS=["*"]

# Logging (structlog): INFO, DEBUG, WARNING, ERROR; LOG_FORMAT=json or console
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional Sentry error tracking (leave unset to disable)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.0

# Speech engine: "whisper" (local Faster-Whisper) or "fun_asr" (Alibaba DashScope cloud)
SPEECH_ENGINE=whisper

# ── Alibaba DashScope Fun-ASR (when SPEECH_ENGINE=fun_asr) ──
# DASHSCOPE_API_KEY=
# Region WebSocket URL: Beijing=wss://dashscope.aliyuncs.com/api-ws/v1/inference
#                       Singapore=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference
# DASHSCOPE_BASE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
# FUN_ASR_MODEL=fun-asr-realtime
# FUN_ASR_LANGUAGE_HINTS=["zh","en"]

# Faster-Whisper (speech WebSocket, when SPEECH_ENGINE=whisper); see app/core/config.py
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD_FILTER=true
WHISPER_BEAM_SIZE=5
SPEECH_PARTIAL_INTERVAL_MS=1500
SPEECH_MIN_PARTIAL_BYTES=9600
# Rolling PCM window (seconds) for partial STT; full buffer still used for final transcript
SPEECH_PARTIAL_WINDOW_SECONDS=30
# Speech WebSocket: require ?access_token=<JWT>
SPEECH_REQUIRE_AUTH=true
# POST /tenants bootstrap: leave empty to disable; set to a long secret and send X-Tenant-Bootstrap-Key
# TENANT_BOOTSTRAP_API_KEY=

# Image uploads (multipart POST /api/v1/media); relative to server working directory
# MEDIA_UPLOAD_DIR=data/uploads
# MEDIA_MAX_BYTES=10485760

# ── AI Agent (OpenAI-compatible endpoint) ──
# Point to any provider: OpenAI, DeepSeek, SiliconFlow, Ollama, vLLM...
AGENT_LLM_BASE_URL=https://api.openai.com/v1
AGENT_LLM_MODEL=gpt-4o
AGENT_LLM_API_KEY=

# Agent system prompt override (leave empty to use built-in default)
# AGENT_SYSTEM_PROMPT=

# ── Web Search (Tavily) ──
TAVILY_API_KEY=
