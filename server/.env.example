POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=todolist
CORS_ORIGINS=["*"]

# Faster-Whisper (speech WebSocket); see app/core/config.py
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD_FILTER=true
WHISPER_BEAM_SIZE=5
SPEECH_PARTIAL_INTERVAL_MS=1500
SPEECH_MIN_PARTIAL_BYTES=9600
